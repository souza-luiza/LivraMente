### ===============================================
### 1. Criar Readlist Simples
### ===============================================
POST {{baseUrl}}/readlists
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "nome": "Livros de FicГ§ГЈo CientГ­fica"
}

### ===============================================
### 2. Criar Readlist Completa (todos os campos)
### ===============================================
POST {{baseUrl}}/readlists
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "nome": "Meus Favoritos 2025",
  "descricao": "Lista com os melhores livros que li este ano",
  "favorito": true,
  "publica": true,
  "capa_url": "https://picsum.photos/400/600"
}

